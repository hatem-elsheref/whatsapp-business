{
    "name": "hatem-elsheref/whatsapp-business",
    "description": "WhatsApp Business SaaS Platform for Laravel - Multi-tenant, OAuth, WhatsApp Cloud API integration",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "whatsapp",
        "whatsapp-business",
        "saas",
        "multi-tenant",
        "meta",
        "facebook"
    ],
    "homepage": "https://github.com/hatem-elsheref/whatsapp-business",
    "readme": "README.md",
    "version": "1.0.7",
    "time": "2026-03-29T20:20:00+00:00",
    "authors": [
        {
            "name": "Hatem Mohamed Elsheref",
            "email": "hatemelsheref99@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "email": "hatemelsheref99@gmail.com",
        "issues": "https://github.com/hatem-elsheref/whatsapp-business/issues",
        "source": "https://github.com/hatem-elsheref/whatsapp-business"
    },
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0|^12.0",
        "laravel/sanctum": "^4.0",
        "guzzlehttp/guzzle": "^7.8",
        "pusher/pusher-php-server": "^7.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "WhatsApp\\Business\\": "src/",
            "WhatsApp\\Business\\Database\\Factories\\": "database/factories/",
            "WhatsApp\\Business\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WhatsApp\\Business\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "WhatsApp\\Business\\Providers\\WhatsAppServiceProvider",
                "WhatsApp\\Business\\Providers\\WhatsAppEventServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
